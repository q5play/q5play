{
	"name": "@q5/q5play",
	"version": "4.0.1",
	"description": "A web-based game engine that uses q5.js WebGPU for graphics and Box2D v3 WASM for physics.",
	"author": "quinton-ashley",
	"exports": "./q5play.js",
	"types": "./q5play.d.ts",
	"tasks": {
		"multi": "ws --https --cors.embedder-policy require-corp --cors.opener-policy same-origin --directory .",
		"v": "npm version patch --force",
		"V": "npm version minor --force"
	},
	"publish": {
		"exclude": [".npmignore", "deno.lock", "Icon?"]
	},
	"imports": {
		"box2d3-wasm": "npm:box2d3-wasm@^5.2.0",
		"q5": "https://jsr.io/@q5/q5"
	}
}
