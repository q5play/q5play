{
	"name": "q5play",
	"version": "4.0.3",
	"author": "quinton-ashley",
	"license": "SEE LICENSE IN LICENSE.md",
	"description": "A web-based game engine that uses q5.js WebGPU for graphics and Box2D v3 WASM for physics.",
	"main": "q5play.js",
	"types": "q5play.d.ts",
	"homepage": "https://q5play.org",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/q5play/q5play.git"
	},
	"keywords": [
		"q5",
		"p5play",
		"p5"
	],
	"scripts": {
		"multi": "ws --https --cors.embedder-policy require-corp --cors.opener-policy same-origin --directory .",
		"v": "npm version patch --force",
		"V": "npm version minor --force",
		"version": "git add -A",
		"postversion": "git push"
	},
	"dependencies": {
		"box2d3-wasm": "^5.2.0",
		"q5": "^4.4.4"
	}
}
